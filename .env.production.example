THIRSTYS_IMAGE=ghcr.io/iamsothirsty/thirstys-waterfall:1.0.3
THIRSTYS_PUBLIC_HOST=thirstys-waterfall.example.com
CADDY_ACME_EMAIL=ops@example.com

SECRET_KEY=replace-with-64-plus-random-hex-or-base64
JWT_SECRET_KEY=replace-with-64-plus-random-hex-or-base64
THIRSTYS_ADMIN_USERNAME=operator
THIRSTYS_ADMIN_PASSWORD_HASH=replace-with-werkzeug-password-hash

WORKERS=4
LOG_LEVEL=info
